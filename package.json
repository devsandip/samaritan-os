{
  "name": "samaritan",
  "version": "0.1.0",
  "description": "Personal agentic OS - Action Center platform",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/api/server.ts",
    "start": "node dist/api/server.js",
    "migrate": "tsx src/cli/migrate.ts",
    "run-capability": "tsx src/cli/run-capability.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/static": "^8.1.1",
    "expr-eval": "^2.0.2",
    "fastify": "^5.2.1",
    "pino": "^9.6.0",
    "yaml": "^2.7.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
